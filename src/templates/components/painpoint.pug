//- 3.1 — Before/after pain point section (PM REVIEW: copy is placeholder)
section.painpoint.block
    .container
        h2.painpoint__title.text-uppercase.text-center See the Damage We <span class="text-blue">Reverse Every Day</span>
        p.painpoint__subtitle.text-center Water damage doesn't wait — and neither do we. Here's what fast, professional restoration looks like.
        .painpoint__grid
            .painpoint__card
                .painpoint__images
                    .painpoint__img.painpoint__img--before
                        img(src="img/work-img-1.jpg", alt="Flooded bedroom before restoration")
                        span.painpoint__label Before
                    .painpoint__img.painpoint__img--after
                        img(src="img/work-img-1-1.jpg", alt="Bedroom after DrySafe restoration")
                        span.painpoint__label After
                .painpoint__context
                    h3.painpoint__heading Flooded Bedroom — Marrickville
                    p.painpoint__detail Water flooded the bedroom causing damage to floors and furnishings. Our crew extracted, dried, and restored the space in under 48 hours.
            .painpoint__card
                .painpoint__images
                    .painpoint__img.painpoint__img--before
                        img(src="img/work-img-2.jpg", alt="Storm water damaged living area before restoration")
                        span.painpoint__label Before
                    .painpoint__img.painpoint__img--after
                        img(src="img/work-img-2-1.jpg", alt="Living area restored after storm water damage")
                        span.painpoint__label After
                .painpoint__context
                    h3.painpoint__heading Storm Water Damage to Living Area — Chatswood
                    p.painpoint__detail Storm water inundated the living area, soaking floors and furniture. Full water extraction and drying completed with minimal disruption.
            .painpoint__card
                .painpoint__images
                    .painpoint__img.painpoint__img--before
                        img(src="img/work-img-3.jpg", alt="Water damaged open area before restoration")
                        span.painpoint__label Before
                    .painpoint__img.painpoint__img--after
                        img(src="img/work-img-3-1.jpg", alt="Open area restored after water damage")
                        span.painpoint__label After
                .painpoint__context
                    h3.painpoint__heading Water Damaged Open Area — Paddington
                    p.painpoint__detail Water damage spread across the open-plan area affecting flooring throughout. Emergency dry-out and restoration completed in days.
        .painpoint__btn.text-center
            +btn('btn btn-primary btn-rounded btn-large', 'SEND HELP NOW')
