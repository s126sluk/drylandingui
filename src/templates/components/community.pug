section.community.block 
	.container 
		.community-grid 
			.community-grid__title 
				h2.community__title.text-uppercase.mb-0.text-center.text-lg-left LOCAL EXPERTS PROUDLY <span class="text-blue">SERVING OUR COMMUNITY</span>
			.community-grid__img
				img.img-rounded.community__img(src="img/community-img-1.jpg" alt="")
				img.img-rounded.community__img(src="img/community-img-2.jpg" alt="")
			.community-grid__description
				.community__description Founded in Sydney, DrySafe is built on a commitment to protect our neighbours. We live and work in the same communities we serve — and we've seen first-hand how stressful water damage can be. When you choose DrySafe, you're choosing a local business that genuinely cares about this city and the people in it.
			.community-grid__btn
				.community__btn.text-center.text-lg-left
					+btn('btn btn-primary btn-rounded btn-large', 'SEND HELP NOW')